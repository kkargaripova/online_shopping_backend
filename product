import java.util.HashMap;
import java.util.Map;
import java.util.Objects;

public abstract class Product {
    private int id;
    private String title;
    private int price;
    private Map<String, String> attributes = new HashMap<>();

    public Product() {
        incrementId();
    }

    public Product(int id, String title, int price, Map<String, String> attributes) {
        this.id = id;
        this.title = title;
        this.price = price;
        this.attributes = attributes;
    }

    private void incrementId() {
        this.id++;
    }

    public abstract void calculatePrice(int quantity, int price);

    @Override
    public boolean equals(Object o) {

        if (this == o) return true; //проверка ссылаются ли на один объект

        if (!(o instanceof Product product)) return false; //проверка на ноль

        return id == product.id; //сравнение id
    }

    @Override
    public int hashCode() {
        return Objects.hash(id);
    }

    public String getId() { return String.valueOf(id); }
    public void setId(int id) { this.id = id; }

    public String getTitle() { return title; }
    public void setTitle(String title) { this.title = title; }

    public int getPrice() { return price; }
    public void setPrice(int price) { this.price = price; }

    public Map<String, String> getAttributes() { return attributes; }
    public void setAttributes(Map<String, String> attributes) { this.attributes = attributes; }
}


class PhysicalProduct extends Product implements payable, financable {
    private boolean isPaidStatus = false;
    private double currentBalance = 150000.0;

    public PhysicalProduct(int id, String title, int price, Map<String, String> attributes) {
        super(id, title, price, attributes);
    }

    @Override
    public double getFinalPrice() { return (double) getPrice(); }

    @Override
    public void pay(double amount) {
        if (hasEnoughMoney(amount)) {
            isPaidStatus = true;
            currentBalance -= amount;
            System.out.println("Успешная оплата: " + getTitle());
        } else {
            System.out.println("Ошибка: недостаточно средств для " + getTitle());
        }
    }

    @Override
    public boolean isPaid() { return isPaidStatus; }

    @Override
    public double checkBalance() { return currentBalance; }

    @Override
    public boolean hasEnoughMoney(double money) { return currentBalance >= money; }

    @Override
    public String getFinancialStatus() {
        if (isPaidStatus) {
            return "Товар: '" + getTitle() + "' оплачен.";
        } else {
            return "Товар '" + getTitle() + "' ожидает оплаты. Требуется: " + getFinalPrice();
        }
    }

    @Override
    public void calculatePrice(int quantity, int price) {
        System.out.println("Расчет: " + (quantity * price));
    }
}
